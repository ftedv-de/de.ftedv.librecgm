{
  "name": {
    "en": "Glucose stats",
    "de": "Glukosestatistik"
  },
  "description": {
    "en": "Shows current glucose and 24 hour statistics.",
    "de": "Zeigt aktuellen Glukosewert und 24h-Statistik."
  },
  "height": "16",
  "devices": {
    "type": "global",
    "singular": true,
    "filter": {
      "capabilities": "measure_glucose_mgdl"
    }
  },
  "api": {
    "getGlucoseHistory": {
      "method": "GET",
      "path": "/getGlucoseHistory"
    }
  },
  "settings": [
    {
      "id": "glucose_unit",
      "type": "dropdown",
      "title": {
        "en": "Glucose unit",
        "de": "Glukoseeinheit"
      },
      "value": "mgdl",
      "values": [
        {
          "id": "mgdl",
          "label": {
            "en": "mg/dL",
            "de": "mg/dL"
          }
        },
        {
          "id": "mmol",
          "label": {
            "en": "mmol/L",
            "de": "mmol/L"
          }
        }
      ]
    }
  ]
}